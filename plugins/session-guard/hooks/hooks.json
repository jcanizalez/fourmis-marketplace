{
  "description": "Autonomous session management — progress checkpointing, stuck loop detection, TODO scanning, session summaries, and drift detection",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/progress-checkpoint.sh",
            "timeout": 30,
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/stuck-loop-detector.sh",
            "timeout": 5,
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/drift-detector.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/todo-scanner.sh",
            "timeout": 15,
            "statusMessage": "Scanning for incomplete work..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/session-summary.sh",
            "timeout": 10,
            "statusMessage": "Generating session summary..."
          }
        ]
      }
    ]
  }
}