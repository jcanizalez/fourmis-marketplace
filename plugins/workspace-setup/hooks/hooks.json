{
  "description": "Workspace detection and onboarding hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/detect-stack.sh",
            "timeout": 10,
            "statusMessage": "Detecting project stack..."
          }
        ]
      }
    ]
  }
}
